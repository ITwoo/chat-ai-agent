generator client {
    provider     = "prisma-client"
    output       = "../src/generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

enum BoardStatus {
    PUBLIC
    PRIVATE
}

enum ChatMessageRole {
    USER
    ASSISTANT
    SYSTEM
}

enum  ChatMessageStatus {
    COMPLETED
    CANCELLED
    FAILED
}

enum RagDocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model User {
    id       Int    @id @default(autoincrement())
    username String @unique @db.VarChar(50)
    password String @db.VarChar(255)

    boards    Board[]
    chatRooms ChatRoom[]
    expense   Expense[]
    refreshTokenSessions RefreshTokenSession[]
    ragDocuments RagDocument[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Board {
    id          Int         @id @default(autoincrement())
    title       String      @db.VarChar(100)
    description String      @db.Text
    status      BoardStatus @default(PUBLIC)

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([status])
    @@index([createdAt])
}

model ChatRoom {
    id    Int    @id @default(autoincrement())
    title String @default("새 채팅") @db.VarChar(100)

    userId Int
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    messages ChatMessage[]
    pendingApproval AgentPendingApproval?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([createdAt])
    @@index([updatedAt])
}

model ChatMessage {
    id Int @id @default(autoincrement())

    roomId Int
    room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

    role    ChatMessageRole
    content String          @db.Text
    status  ChatMessageStatus @default(COMPLETED)

    createdAt DateTime @default(now())

    @@index([roomId])
    @@index([roomId, createdAt])
    @@index([createdAt])
    @@index([status])
}

model Expense {
    id Int @id @default(autoincrement())
    userId Int
    amount Int
    category String
    title String
    memo String?
    spentAt DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, spentAt])
    @@index([userId, category])
}

model RefreshTokenSession {
    id        Int       @id @default(autoincrement())
    userId    Int
    tokenHash String    @db.VarChar(255)
    expiresAt DateTime
    revokedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([expiresAt])
    @@index([revokedAt])
}

model AgentPendingApproval {
    id Int @id @default(autoincrement())

    approvalId String @unique @db.Uuid
    threadId   String @db.VarChar(255)

    roomId Int      @unique
    room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

    originUserMessageId Int
    request             Json

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([threadId])
    @@index([originUserMessageId])
}

model RagDocument {
  id            Int               @id @default(autoincrement())
  userId        Int
  fileName      String            @db.VarChar(255)
  storageKey    String            @unique @db.VarChar(255)
  mimeType      String            @db.VarChar(100)
  sizeBytes     Int
  status        RagDocumentStatus @default(PENDING)
  error         String?           @db.Text

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks RagDocumentChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([createdAt])
}

model RagDocumentChunk {
  id         Int    @id @default(autoincrement())
  documentId Int
  chunkIndex Int
  content    String @db.Text
  tokenCount Int?
  embedding  Unsupported("vector")?

  document RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}